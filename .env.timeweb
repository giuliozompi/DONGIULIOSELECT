# ================================================================
# Don Giulio Select — Variabili d'ambiente per Timeweb
# Copia i valori dal pannello Secrets di Replit
# ================================================================

# ── SERVER ──────────────────────────────────────────────────────
NODE_ENV=production
TZ=Europe/Moscow
# APP_BASE_URL = URL pubblico del sito (es. https://dongiulioselect.ru)
APP_BASE_URL=https://dongiulioselect.ru
APP_PUBLIC_URL=https://dongiulioselect.ru
APP_URL=https://dongiulioselect.ru
PUBLIC_BASE_URL=https://dongiulioselect.ru

# ── DATABASE (Neon PostgreSQL) ───────────────────────────────────
# Copia il valore di DATABASE_URL da Replit Secrets
DATABASE_URL=

# ── AUTH ────────────────────────────────────────────────────────
# Genera una stringa casuale lunga (es. openssl rand -hex 32)
SESSION_SECRET=
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── TELEGRAM ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_MINI_APP_URL=https://t.me/dongiuliocatalog_bot/DGSCatalog
TELEGRAM_WEBHOOK_SECRET=
MASTER_ADMIN_USER_IDS=
MANAGER_TELEGRAM_CHAT_IDS=

# ── PAGAMENTI ───────────────────────────────────────────────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
SBP_WEBHOOK_SECRET=

# ── NOTIFICHE ───────────────────────────────────────────────────
RESEND_API_KEY=
MANAGER_EMAILS=

# ── WHATSAPP ────────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── AI ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ── INDIRIZZI (DaData) ──────────────────────────────────────────
DADATA_API_TOKEN=

# ── CONSEGNA YANDEX ─────────────────────────────────────────────
YANDEX_DOSTAVKA_CLIENT_ID=
YANDEX_DOSTAVKA_TOKEN=
YANDEX_GO_CLIENT_ID=
YANDEX_GO_CLIENT_SECRET=
YANDEX_GO_TOKEN=
YANDEX_OAUTH_TOKEN_URL=
YANDEX_WEBHOOK_SECRET=

# ── CONSEGNA CDEK ───────────────────────────────────────────────
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=
CDEK_FROM_CITY_CODE=
# CDEK_TEST_MODE=true  (decommentare per test)

# ── OBJECT STORAGE ──────────────────────────────────────────────
# Se usi ancora Replit Object Storage, lascia vuoti.
# Per produzione su Timeweb considera S3 o Selectel.
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
